# Stage 1: Build Stage
FROM mcr.microsoft.com/dotnet/sdk:6.0 AS build

# WORKDIR /src

# restore
COPY ["vscodeApi.csproj", "vscodeApi/"]
RUN dotnet restore 'vscodeApi/vscodeApi.csproj'

# build
COPY ["./", "vscodeApi/"]
RUN dotnet build 'vscodeApi/vscodeApi.csproj' -c Relase -o /app/build

# Stage 2: Publish Stage
FROM build AS publish
RUN dotnet publish 'vscodeApi/vscodeApi.csproj' -c Relase -o /app/publish

# Stage 3: Run stage
FROM  mcr.microsoft.com/dotnet/aspnet:6.0
WORKDIR /app
COPY --from=publish /app/publish .
ENTRYPOINT ["dotnet", "vscodeApi.dll"]